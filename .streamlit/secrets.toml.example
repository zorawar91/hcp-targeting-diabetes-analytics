# Copy this file to .streamlit/secrets.toml and fill in your Neon credentials.
# NEVER commit secrets.toml to git — it is listed in .gitignore.
#
# Get these values from your Neon project dashboard:
# https://console.neon.tech → your project → Connection Details

[postgres]
host     = "ep-xxxx-xxxx.us-east-2.aws.neon.tech"
port     = 5432
dbname   = "neondb"
user     = "neondb_owner"
password = "your_neon_password_here"
sslmode  = "require"
